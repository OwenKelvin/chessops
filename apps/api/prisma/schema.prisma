// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  passwordHash    String?
  displayName     String?
  avatarUrl       String?
  emailVerifiedAt DateTime?
  isSuspended     Boolean         @default(false)
  role            String          @default("user")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  sessions        Session[]
  oauthAccounts   OauthAccount[]
  mfaSecret       MfaSecret?
  recoveryTokens  AccountRecovery[]
  emailVerification EmailVerification?
  apiKeys         ApiKey[]
  apps            App[]

  @@index([email])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model OauthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String   // "google" | "github"
  providerAccountId String   // User's ID with the provider
  accessToken       String
  refreshToken      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model MfaSecret {
  id           String   @id @default(cuid())
  userId       String   @unique
  secret       String
  backupCodes  String   // JSON array of backup codes
  enabled      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AccountRecovery {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  name        String   // User-friendly name for the key
  keyHash     String   @unique // Hashed API key (store sha256 of key)
  prefix      String   // First 8 chars of the key for identification (e.g., "sk_live_...")
  permissions String   // JSON array of permissions
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
  @@index([prefix])
}

model App {
  id              String   @id @default(cuid())
  userId          String
  name            String
  description     String?
  callbackUrls    String   // JSON array of OAuth callback URLs
  redirectUris    String   // JSON array of redirect URIs
  clientId        String   @unique
  clientSecret    String   @unique
  isActive        Boolean  @default(true)
  webhookUrl      String?
  webhookSecret   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientId])
}
